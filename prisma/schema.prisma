generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  TOPIC
  PDF
  MANUAL
}

enum CardType {
  FLASHCARD
  MCQ
  IDENTIFICATION
  TRUE_FALSE
  CLOZE
}

enum StudyMode {
  LEARN
  QUIZ
  TEST
}

enum ShareType {
  LINK
  CODE
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  preferences     Json      @default("{}")
  streakCount     Int       @default(0) @map("streak_count")
  weeklyGoal      Int       @default(5) @map("weekly_goal")
  streakUpdatedAt      DateTime? @map("streak_updated_at")
  streakFreezeAvailable Boolean  @default(true) @map("streak_freeze_available")
  streakFreezeUsedAt   DateTime? @map("streak_freeze_used_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  aiProvider    String? @map("ai_provider")
  aiApiKey      String? @map("ai_api_key")
  aiBaseUrl     String? @map("ai_base_url")
  aiModelName   String? @map("ai_model_name")

  decks           Deck[]
  studySessions   StudySession[]
  reviewSchedules ReviewSchedule[]
  shareArtifacts  ShareArtifact[]

  @@map("users")
}

model Deck {
  id          String     @id @default(uuid()) @db.Uuid
  ownerId     String     @map("owner_id") @db.Uuid
  title       String
  subject     String
  description String?
  sourceType  SourceType @map("source_type")
  cardCount   Int        @default(0) @map("card_count")
  isShared    Boolean    @default(false) @map("is_shared")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cards           Card[]
  sourceDocuments SourceDocument[]
  studySessions   StudySession[]
  shareArtifacts  ShareArtifact[]

  @@index([ownerId])
  @@map("decks")
}

model Card {
  id            String   @id @default(uuid()) @db.Uuid
  deckId        String   @map("deck_id") @db.Uuid
  type          CardType
  prompt        String
  answer        String
  explanation   String?
  options       Json?
  clozeText     String?  @map("cloze_text")
  sourceChunkId String?  @map("source_chunk_id")
  position      Int      @default(0)
  isDraft       Boolean  @default(true) @map("is_draft")
  createdAt     DateTime @default(now()) @map("created_at")

  deck            Deck             @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviewSchedules ReviewSchedule[]
  sessionAnswers  SessionAnswer[]

  @@index([deckId])
  @@map("cards")
}

model SourceDocument {
  id            String   @id @default(uuid()) @db.Uuid
  deckId        String   @map("deck_id") @db.Uuid
  filename      String
  mimeType      String   @map("mime_type")
  storagePath   String   @map("storage_path")
  extractedText String   @map("extracted_text") @db.Text
  chunks        Json
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@map("source_documents")
}

model StudySession {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  deckId          String    @map("deck_id") @db.Uuid
  mode            StudyMode
  totalCards      Int       @map("total_cards")
  correctCount    Int       @default(0) @map("correct_count")
  durationSeconds Int       @default(0) @map("duration_seconds")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck    Deck            @relation(fields: [deckId], references: [id], onDelete: Cascade)
  answers SessionAnswer[]

  @@index([userId])
  @@index([deckId])
  @@map("study_sessions")
}

model SessionAnswer {
  id             String   @id @default(uuid()) @db.Uuid
  sessionId      String   @map("session_id") @db.Uuid
  cardId         String   @map("card_id") @db.Uuid
  isCorrect      Boolean  @map("is_correct")
  confidence     Int?
  responseTimeMs Int?     @map("response_time_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  session StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  card    Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([cardId])
  @@map("session_answers")
}

model ReviewSchedule {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  cardId         String    @map("card_id") @db.Uuid
  easeFactor     Float     @default(2.5) @map("ease_factor")
  intervalDays   Int       @default(0) @map("interval_days")
  repetitions    Int       @default(0)
  nextReviewAt   DateTime  @map("next_review_at")
  lastReviewedAt DateTime? @map("last_reviewed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, nextReviewAt])
  @@map("review_schedules")
}

model ShareArtifact {
  id          String    @id @default(uuid()) @db.Uuid
  deckId      String    @map("deck_id") @db.Uuid
  creatorId   String    @map("creator_id") @db.Uuid
  shareType   ShareType @map("share_type")
  code        String    @unique
  importCount Int       @default(0) @map("import_count")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  deck    Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@map("share_artifacts")
}
